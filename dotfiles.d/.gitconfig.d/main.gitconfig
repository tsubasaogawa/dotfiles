[core]
  editor = vi
  autocrlf = false

[alias]
  st = status
  ci = commit -m
  br = branch
  sw = switch
  ps = push origin HEAD

[color]
  ui = auto

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[advice]
  forceDeleteBranch = true

[include]
  path = ~/.dotfiles.d/.gitconfig.d/.gitconfig.local

[pull]
  rebase = false
